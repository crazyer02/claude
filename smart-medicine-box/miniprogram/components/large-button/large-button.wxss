.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  font-size: 36rpx;
  font-weight: 600;
  padding: 24rpx 48rpx;
  min-height: 96rpx;
  transition: all 0.3s;
}

.btn:active {
  transform: scale(0.96);
  opacity: 0.9;
}

.btn-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.btn-loading {
  font-size: 36rpx;
  margin-right: 12rpx;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.btn-text {
  font-size: 36rpx;
}

/* 类型样式 */
.btn-primary {
  background: linear-gradient(135deg, #4A90D9, #6BA5E7);
  color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 217, 0.3);
}

.btn-success {
  background: #52C41A;
  color: #FFFFFF;
}

.btn-warning {
  background: #FAAD14;
  color: #FFFFFF;
}

.btn-outline {
  background: transparent;
  border: 3rpx solid #4A90D9;
  color: #4A90D9;
}

.btn-danger {
  background: #FF4D4F;
  color: #FFFFFF;
}

.btn-disabled {
  opacity: 0.5;
}
