<!-- 家人绑定 -->
<view class="page-container font-{{fontSizeMode}}">

  <!-- 角色切换 -->
  <view class="role-switch">
    <view class="role-tab {{userType === 'elderly' ? 'active' : ''}}" bindtap="switchRole" data-role="elderly">
      <text>👴 我是老人</text>
    </view>
    <view class="role-tab {{userType === 'family' ? 'active' : ''}}" bindtap="switchRole" data-role="family">
      <text>👨‍👩‍👧 我是家人</text>
    </view>
  </view>

  <!-- ===== 老人端 ===== -->
  <view wx:if="{{userType === 'elderly'}}">
    <view class="card">
      <view class="card-title">我的绑定码</view>
      <text class="info-text">让家人扫描下方二维码即可绑定</text>
      <view class="qrcode-wrap" bindtap="previewQrcode">
        <image class="qrcode-img" src="{{qrcodeUrl}}" mode="aspectFit" show-menu-by-longpress />
        <text class="qrcode-hint">点击放大</text>
      </view>
      <view class="member-list" wx:if="{{familyMembers.length > 0}}">
        <text class="section-label">已绑定的家人</text>
        <view class="member-item" wx:for="{{familyMembers}}" wx:key="id">
          <image class="member-avatar" wx:if="{{item.avatar_url}}" src="{{item.avatar_url}}" mode="aspectFill" />
          <view wx:else class="avatar-placeholder"><text>👤</text></view>
          <text class="member-name">{{item.nickname || '家人'}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ===== 家人端 ===== -->
  <view wx:if="{{userType === 'family'}}">
    <view class="card">
      <view class="card-title">绑定老人</view>
      <view class="scan-section" bindtap="onScanCode">
        <text class="scan-icon">📷</text>
        <text class="scan-text">点击扫码绑定老人</text>
        <text class="scan-sub">让老人切换到「我是老人」展示二维码</text>
      </view>

      <view class="elderly-list" wx:if="{{bindedElderly.length > 0}}">
        <text class="section-label">已绑定的老人</text>
        <view class="elderly-item"
          wx:for="{{bindedElderly}}" wx:key="id"
          data-id="{{item.id}}" bindtap="goElderlyDetail">
          <image class="elderly-avatar" wx:if="{{item.avatar_url}}" src="{{item.avatar_url}}" mode="aspectFill" />
          <view wx:else class="avatar-placeholder"><text>👴</text></view>
          <view class="elderly-info">
            <text class="elderly-name">{{item.nickname || '老人'}} ({{item.age || '未知'}}岁)</text>
          </view>
          <view class="elderly-rate">
            <text class="rate-number" style="color: {{item.today_adherence_rate >= 80 ? '#52C41A' : item.today_adherence_rate >= 50 ? '#FAAD14' : '#FF4D4F'}}">
              {{item.today_adherence_rate}}%
            </text>
            <text class="rate-label">今日依从</text>
          </view>
          <text class="arrow-right">▶</text>
        </view>
      </view>

      <view wx:if="{{bindedElderly.length === 0 && !loading}}" class="empty-state">
        <text class="text">还没有绑定老人</text>
      </view>
    </view>
  </view>
</view>
