/* 角色切换 */
.role-switch {
  display: flex;
  background: var(--bg-card);
  border-radius: var(--radius-round);
  padding: 6rpx;
  margin-bottom: var(--space-md);
  box-shadow: var(--shadow-card);
}

.role-tab {
  flex: 1;
  text-align: center;
  padding: var(--space-sm);
  border-radius: var(--radius-round);
  font-size: var(--font-md);
  color: var(--text-secondary);
  transition: all 0.3s;
}

.role-tab.active {
  background: var(--primary);
  color: #FFFFFF;
  font-weight: 600;
}

.info-text {
  font-size: var(--font-sm);
  color: var(--text-hint);
  margin-bottom: var(--space-md);
}

.section-label {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-secondary);
  display: block;
  margin: var(--space-lg) 0 var(--space-sm);
}

/* 二维码 */
.qrcode-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-lg);
  background: #FAFBFC;
  border-radius: var(--radius-md);
  margin-bottom: var(--space-md);
}

.qrcode-img {
  width: 360rpx;
  height: 360rpx;
  border: 8rpx solid #FFFFFF;
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
}

.qrcode-hint {
  font-size: var(--font-sm);
  color: var(--text-hint);
  margin-top: var(--space-sm);
}

/* 家人列表 */
.member-list {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-md);
}

.member-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.member-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #F5F7FA;
}

.member-name {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  margin-top: var(--space-xs);
}

/* 扫码按钮 */
.scan-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-xl);
  background: linear-gradient(135deg, #E6F4FF, #F0F8FF);
  border: 3rpx dashed var(--primary);
  border-radius: var(--radius-lg);
  margin-bottom: var(--space-lg);
}

.scan-icon {
  font-size: 72rpx;
  margin-bottom: var(--space-sm);
}

.scan-text {
  font-size: var(--font-lg);
  color: var(--primary);
  font-weight: 600;
}

.scan-sub {
  font-size: var(--font-sm);
  color: var(--text-hint);
  margin-top: 4rpx;
}

/* 老人列表 */
.elderly-item {
  display: flex;
  align-items: center;
  padding: var(--space-md);
  background: #FAFBFC;
  border-radius: var(--radius-md);
  margin-bottom: var(--space-sm);
}

.elderly-item:active { opacity: 0.7; }

.elderly-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #F5F7FA;
}

.avatar-placeholder {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #F5F7FA;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.elderly-info {
  flex: 1;
  margin: 0 var(--space-md);
}

.elderly-name {
  font-size: var(--font-lg);
  font-weight: 600;
  display: block;
}

.elderly-contact {
  font-size: var(--font-sm);
  color: var(--text-hint);
}

.elderly-rate {
  text-align: center;
  margin-right: var(--space-sm);
}

.rate-number {
  font-size: var(--font-xl);
  font-weight: 700;
  display: block;
}

.rate-label {
  font-size: var(--font-xs);
  color: var(--text-hint);
}

.arrow-right {
  font-size: var(--font-sm);
  color: var(--text-hint);
}
