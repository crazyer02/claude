/* 用户卡片 */
.user-card {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #4A90D9, #6BA5E7);
  border-radius: var(--radius-lg);
  padding: var(--space-xl);
  margin-bottom: var(--space-lg);
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.5);
  background: #E6F4FF;
}

.user-avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.5);
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
}

.user-info {
  flex: 1;
  margin-left: var(--space-lg);
}

.user-name {
  font-size: var(--font-xl);
  font-weight: 700;
  color: #FFFFFF;
  display: block;
}

.user-age {
  font-size: var(--font-md);
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
  display: block;
}

.user-phone {
  font-size: var(--font-md);
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

.edit-btn {
  color: #FFFFFF;
  font-size: var(--font-md);
  padding: var(--space-xs) var(--space-md);
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  border-radius: var(--radius-round);
}

/* 登录卡片 */
.login-card {
  display: flex;
  align-items: center;
  padding: var(--space-xl);
}

.login-icon {
  font-size: 100rpx;
  margin-right: var(--space-lg);
}

.login-text {
  font-size: var(--font-xl);
  color: #FFFFFF;
  font-weight: 600;
}

/* 描述文本 */
.section-desc {
  font-size: var(--font-sm);
  color: var(--text-hint);
  display: block;
  margin-bottom: var(--space-md);
}

/* 字体选择器 */
.font-size-selector {
  display: flex;
  gap: var(--space-md);
}

.font-option {
  flex: 1;
  text-align: center;
  padding: var(--space-md);
  border: 3rpx solid var(--border);
  border-radius: var(--radius-md);
}

.font-option.active {
  border-color: var(--primary);
  background: #E6F4FF;
}

.font-sample {
  font-weight: 600;
  color: var(--text-primary);
}

/* 菜单 */
.menu-card {
  padding: 0;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: var(--space-lg);
  border-bottom: 2rpx solid var(--border);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #FAFBFC;
}

.menu-icon {
  font-size: var(--font-xl);
  margin-right: var(--space-md);
}

.menu-text {
  flex: 1;
  font-size: var(--font-lg);
  color: var(--text-primary);
}

.menu-arrow {
  font-size: var(--font-xs);
  color: var(--text-hint);
}

/* 版本号 */
.version-text {
  text-align: center;
  font-size: var(--font-sm);
  color: var(--text-hint);
  padding: var(--space-xl) 0;
}
