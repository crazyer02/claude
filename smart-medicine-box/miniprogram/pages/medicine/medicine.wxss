/* 库存不足提醒 */
.alert-banner {
  display: flex;
  align-items: center;
  background: #FFF7E6;
  border: 2rpx solid #FFD591;
  border-radius: var(--radius-md);
  padding: var(--space-md);
  margin-bottom: var(--space-md);
}

.alert-icon {
  font-size: var(--font-xl);
  margin-right: var(--space-sm);
}

.alert-text {
  font-size: var(--font-md);
  color: #D46B08;
  flex: 1;
}

/* 药品网格 */
.medicine-grid {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.medicine-card-item {
  position: relative;
  background: var(--bg-card);
  border-radius: var(--radius-md);
  padding: var(--space-lg);
  box-shadow: var(--shadow-card);
}

.medicine-card-item:active {
  transform: scale(0.98);
  opacity: 0.8;
}

/* 库存角标 */
.stock-badge {
  position: absolute;
  top: var(--space-sm);
  right: var(--space-sm);
  padding: 4rpx var(--space-sm);
  border-radius: var(--radius-round);
  font-size: var(--font-xs);
}

.stock-badge.low {
  background: #FFF2F0;
  color: var(--danger);
}

.stock-badge.normal {
  background: #F6FFED;
  color: var(--success);
}

/* 药品图片 */
.medicine-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: var(--radius-md);
  background: #F5F7FA;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--space-md);
}

.medicine-image image {
  width: 100%;
  height: 100%;
  border-radius: var(--radius-md);
}

.medicine-icon {
  font-size: 60rpx;
}

/* 药品信息 */
.medicine-name {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--text-primary);
  display: block;
}

.medicine-spec {
  font-size: var(--font-sm);
  color: var(--text-hint);
  display: block;
  margin-top: 4rpx;
}

.medicine-dosage {
  font-size: var(--font-lg);
  color: var(--primary);
  font-weight: 600;
  display: block;
  margin-top: 8rpx;
}

.medicine-position {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  margin-top: 4rpx;
}

/* 操作区 */
.medicine-actions {
  display: flex;
  gap: var(--space-sm);
  margin-top: var(--space-md);
  padding-top: var(--space-md);
  border-top: 2rpx solid var(--border);
}

.mini-btn {
  flex: 1;
  text-align: center;
  padding: var(--space-sm);
  border-radius: var(--radius-round);
  font-size: var(--font-sm);
  font-weight: 500;
  background: #E6F4FF;
  color: var(--primary);
}

.mini-btn:active {
  opacity: 0.7;
}

.mini-btn.outline {
  background: transparent;
  border: 2rpx solid var(--primary);
}

.mini-btn.danger {
  background: #FFF2F0;
  color: var(--danger);
}
