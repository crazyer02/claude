/* 日期导航 */
.date-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-md) 0;
}

.date-arrow {
  font-size: var(--font-xl);
  color: var(--primary);
  padding: var(--space-sm) var(--space-md);
}

.date-display {
  display: flex;
  align-items: center;
  padding: var(--space-sm) var(--space-lg);
  background: var(--bg-card);
  border-radius: var(--radius-round);
  box-shadow: var(--shadow-card);
}

.date-text {
  font-size: var(--font-lg);
  font-weight: 600;
  margin-right: var(--space-sm);
}

.date-arrow-down {
  font-size: var(--font-xs);
  color: var(--text-hint);
}

/* 状态筛选 */
.status-filter {
  display: flex;
  gap: var(--space-sm);
  margin-bottom: var(--space-md);
}

.filter-item {
  flex: 1;
  text-align: center;
  padding: var(--space-sm);
  border-radius: var(--radius-round);
  font-size: var(--font-md);
  background: var(--bg-card);
  color: var(--text-secondary);
}

.filter-item.active {
  background: var(--primary);
  color: #FFFFFF;
  font-weight: 600;
}

/* 记录列表 */
.record-item {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  background: var(--bg-card);
  border-radius: var(--radius-md);
  padding: var(--space-lg);
  margin-bottom: var(--space-sm);
  box-shadow: var(--shadow-card);
  border-left: 8rpx solid var(--border);
}

.record-item.taken {
  border-left-color: var(--success);
}

.record-item.missed {
  border-left-color: var(--danger);
}

.record-item.skipped {
  border-left-color: var(--warning);
}

/* 药名行：左边药名，右边用量 */
.record-name-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  width: 100%;
  margin-bottom: var(--space-sm);
}

.record-medicine {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--text-primary);
}

.record-dosage {
  font-size: var(--font-lg);
  color: var(--primary);
  font-weight: 600;
  white-space: nowrap;
  margin-left: 20rpx;
}

/* 时间明细：计划和实际分两行 */
.record-times {
  width: 100%;
}

.record-time {
  font-size: var(--font-md);
  color: var(--text-secondary);
  display: block;
  line-height: 1.8;
}

.record-actual-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.record-actual {
  font-size: var(--font-md);
  color: var(--warning);
  font-weight: 500;
}

/* 状态标签 */
.status-tag {
  font-size: var(--font-sm);
  padding: 4rpx var(--space-md);
  border-radius: var(--radius-round);
  font-weight: 600;
}

.status-tag.taken {
  background: #F6FFED;
  color: var(--success);
}

.status-tag.missed {
  background: #FFF2F0;
  color: var(--danger);
}

.status-tag.skipped {
  background: #FFFBE6;
  color: var(--warning);
}
