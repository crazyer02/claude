/**
 * 智能药箱小程序 - 全局样式
 * 设计原则：大字体、高对比度、大触控区域、简洁布局
 */

/* ==================== CSS 变量 ==================== */
page {
  /* 主色调 - 柔和蓝 */
  --primary: #4A90D9;
  --primary-light: #6BA5E7;
  --primary-dark: #3570B0;

  /* 语义色 */
  --success: #52C41A;
  --warning: #FAAD14;
  --danger: #FF4D4F;

  /* 中性色 */
  --text-primary: #1A1A1A;
  --text-secondary: #666666;
  --text-hint: #999999;
  --bg-page: #F5F7FA;
  --bg-card: #FFFFFF;
  --border: #E8E8E8;

  /* 圆角 */
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-round: 999rpx;

  /* 间距 */
  --space-xs: 8rpx;
  --space-sm: 16rpx;
  --space-md: 24rpx;
  --space-lg: 32rpx;
  --space-xl: 48rpx;

  /* 阴影 */
  --shadow-card: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  --shadow-btn: 0 8rpx 24rpx rgba(74, 144, 217, 0.3);

  /* 字体大小 (针对老年人放大) */
  --font-xs: 22rpx;
  --font-sm: 26rpx;
  --font-md: 30rpx;
  --font-lg: 36rpx;
  --font-xl: 42rpx;
  --font-xxl: 52rpx;

  background-color: var(--bg-page);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: var(--font-md);
  color: var(--text-primary);
  line-height: 1.6;
}

/* ==================== 字体大小模式 ==================== */
.font-large {
  --font-xs: 26rpx;
  --font-sm: 30rpx;
  --font-md: 36rpx;
  --font-lg: 42rpx;
  --font-xl: 50rpx;
  --font-xxl: 60rpx;
}

.font-xlarge {
  --font-xs: 32rpx;
  --font-sm: 36rpx;
  --font-md: 44rpx;
  --font-lg: 52rpx;
  --font-xl: 62rpx;
  --font-xxl: 74rpx;
}

.font-normal {
  --font-xs: 22rpx;
  --font-sm: 26rpx;
  --font-md: 30rpx;
  --font-lg: 36rpx;
  --font-xl: 42rpx;
  --font-xxl: 52rpx;
}

/* ==================== 通用布局 ==================== */
.page-container {
  min-height: 100vh;
  padding: var(--space-md);
  padding-bottom: 120rpx; /* 底部 tabBar 空间 */
  box-sizing: border-box;
}

.card {
  background: var(--bg-card);
  border-radius: var(--radius-md);
  padding: var(--space-lg);
  margin-bottom: var(--space-md);
  box-shadow: var(--shadow-card);
}

.card-title {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--space-md);
  display: flex;
  align-items: center;
}

.card-title::before {
  content: '';
  width: 6rpx;
  height: 32rpx;
  background: var(--primary);
  border-radius: var(--radius-sm);
  margin-right: var(--space-sm);
}

/* ==================== 按钮 ==================== */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-round);
  font-size: var(--font-lg);
  font-weight: 500;
  padding: var(--space-sm) var(--space-xl);
  min-height: 88rpx;
  border: none;
  transition: all 0.3s;
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
  color: #FFFFFF;
  box-shadow: var(--shadow-btn);
}

.btn-primary:active {
  transform: scale(0.96);
  opacity: 0.9;
}

.btn-success {
  background: var(--success);
  color: #FFFFFF;
}

.btn-warning {
  background: var(--warning);
  color: #FFFFFF;
}

.btn-outline {
  background: transparent;
  border: 3rpx solid var(--primary);
  color: var(--primary);
}

.btn-danger {
  background: var(--danger);
  color: #FFFFFF;
}

.btn-block {
  width: 100%;
}

.btn-disabled {
  opacity: 0.5;
  pointer-events: none;
}

/* ==================== 表单 ==================== */
.form-group {
  margin-bottom: var(--space-lg);
}

.form-label {
  font-size: var(--font-lg);
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: var(--space-sm);
  display: block;
}

.form-input {
  width: 100%;
  height: 88rpx;
  border: 3rpx solid var(--border);
  border-radius: var(--radius-md);
  padding: 0 var(--space-md);
  font-size: var(--font-lg);
  background: var(--bg-card);
  box-sizing: border-box;
}

.form-input:focus {
  border-color: var(--primary);
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  border: 3rpx solid var(--border);
  border-radius: var(--radius-md);
  padding: var(--space-md);
  font-size: var(--font-lg);
  background: var(--bg-card);
  box-sizing: border-box;
}

.form-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  height: 88rpx;
  border: 3rpx solid var(--border);
  border-radius: var(--radius-md);
  padding: 0 var(--space-md);
  font-size: var(--font-lg);
  background: var(--bg-card);
  box-sizing: border-box;
}

.form-picker .arrow {
  color: var(--text-hint);
  font-size: var(--font-sm);
}

/* ==================== 标签/徽章 ==================== */
.badge {
  display: inline-flex;
  align-items: center;
  padding: var(--space-xs) var(--space-sm);
  border-radius: var(--radius-round);
  font-size: var(--font-sm);
  font-weight: 500;
}

.badge-success {
  background: #F6FFED;
  color: var(--success);
}

.badge-warning {
  background: #FFFBE6;
  color: var(--warning);
}

.badge-danger {
  background: #FFF2F0;
  color: var(--danger);
}

.badge-primary {
  background: #E6F4FF;
  color: var(--primary);
}

/* ==================== 空状态 ==================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-xl) 0;
}

.empty-state .icon {
  font-size: 100rpx;
  margin-bottom: var(--space-md);
  opacity: 0.4;
}

.empty-state .text {
  font-size: var(--font-lg);
  color: var(--text-hint);
}

/* ==================== 分割线 ==================== */
.divider {
  height: 2rpx;
  background: var(--border);
  margin: var(--space-md) 0;
}

/* ==================== 浮动操作按钮 ==================== */
.fab {
  position: fixed;
  right: var(--space-lg);
  bottom: 160rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: var(--primary);
  color: #FFFFFF;
  font-size: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 30rpx rgba(74, 144, 217, 0.4);
  z-index: 100;
}

.fab:active {
  transform: scale(0.9);
  opacity: 0.8;
}
